
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the ConnectU application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "name": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri"
        },
        "bio": {
          "type": "string"
        },
        "balance": {
          "type": "number",
          "default": 0
        },
        "currency": {
          "type": "string",
          "default": "COIN"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "balanceUpdatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "availability": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "online",
                "offline"
              ]
            },
            "until": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "createdAt",
        "balance"
      ]
    },
    "WalletLedgerEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WalletLedgerEntry",
      "type": "object",
      "description": "Represents a single transaction in the wallet ledger.",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["topup", "call_payment", "payout"] },
        "amount": { "type": "number" },
        "currency": { "type": "string", "default": "COIN" },
        "balanceAfter": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["posted", "pending", "failed"] }
      },
      "required": ["uid", "type", "amount", "balanceAfter", "createdAt", "status"]
    },
    "Call": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Call",
      "type": "object",
      "description": "Represents a call between two users.",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["ringing", "accepted", "ended", "declined", "missed", "expired"] },
        "roomUrl": { "type": "string" },
        "roomName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "offerId": { "type": "string" },
        "pricingSnapshot": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "categoryId": { "type": "string" },
            "subcategoryId": { "type": "string" },
            "currency": { "type": "string", "default": "COIN" },
            "ratePerMinute": { "type": "number" },
            "ratePerFile": { "type": "number" },
            "ratePerQuestion": { "type": "number" },
            "capturedAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["callerId", "receiverId", "status", "createdAt", "updatedAt", "roomName", "roomUrl"]
    },
    "CommunicationOffer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CommunicationOffer",
      "type": "object",
      "description": "A proposal for communication services offered by a user, including pricing details.",
      "properties": {
        "ownerId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "file", "text"] },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "pricing": {
          "type": "object",
          "properties": {
            "ratePerMinute": { "type": "number" },
            "ratePerFile": { "type": "number" },
            "ratePerQuestion": { "type": "number" },
            "currency": { "type": "string", "default": "COIN" }
          }
        },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "type", "pricing", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profile information."
        }
      },
      {
        "path": "/calls/{callId}",
        "definition": {
          "entityName": "Call",
          "schema": { "$ref": "#/backend/entities/Call" },
          "description": "Stores information about calls between users."
        }
      },
      {
        "path": "/communicationOffers/{offerId}",
        "definition": {
          "entityName": "CommunicationOffer",
          "schema": { "$ref": "#/backend/entities/CommunicationOffer" },
          "description": "Stores communication service proposals."
        }
      },
      {
        "path": "/walletLedger/{entryId}",
        "definition": {
          "entityName": "WalletLedgerEntry",
          "schema": { "$ref": "#/backend/entities/WalletLedgerEntry" },
          "description": "Stores transaction history."
        }
      }
    ]
  }
}
