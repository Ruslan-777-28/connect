
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the ConnectU application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "balance": { "type": "number", "default": 0 },
        "held": { "type": "number", "default": 0, "description": "Reserved coins for pending requests" },
        "currency": { "type": "string", "default": "COIN" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "balanceUpdatedAt": { "type": "string", "format": "date-time" },
        "availability": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["online", "offline"] },
            "until": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["id", "email", "name", "createdAt", "balance"]
    },
    "CommunicationRequest": {
      "title": "CommunicationRequest",
      "type": "object",
      "description": "Represents a communication request (Video, Q&A or File).",
      "properties": {
        "id": { "type": "string" },
        "initiatorId": { "type": "string" },
        "authorId": { "type": "string" },
        "payerId": { "type": "string" },
        "payeeId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "text", "file"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "answered", "completed", "declined", "expired", "ringing"] },
        "offerId": { "type": "string" },
        "pricingSnapshot": { "type": "object" },
        "reservedCoins": { "type": "number" },
        "holdId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "answeredAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "lastMessagePreview": { "type": "string" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "A single message in a communication thread.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "kind": { "type": "string", "enum": ["question", "answer", "file", "system"] },
        "text": { "type": "string" },
        "fileMeta": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "channel": { "type": "string", "enum": ["system", "user"] },
        "kind": { "type": "string" },
        "requestId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readAt": { "type": "string", "format": "date-time", "nullable": true }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/communicationRequests/{requestId}",
        "definition": { "entityName": "CommunicationRequest", "schema": { "$ref": "#/backend/entities/CommunicationRequest" } }
      },
      {
        "path": "/communicationRequests/{requestId}/messages/{messageId}",
        "definition": { "entityName": "Message", "schema": { "$ref": "#/backend/entities/Message" } }
      },
      {
        "path": "/notifications/{notificationId}",
        "definition": { "entityName": "Notification", "schema": { "$ref": "#/backend/entities/Notification" } }
      }
    ]
  }
}
