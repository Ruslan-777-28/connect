
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the ConnectU application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "balance": { "type": "number", "default": 0 },
        "currency": { "type": "string", "default": "COIN" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "balanceUpdatedAt": { "type": "string", "format": "date-time" },
        "availability": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["online", "offline"] },
            "until": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["id", "email", "name", "createdAt", "balance"]
    },
    "WalletLedgerEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WalletLedgerEntry",
      "type": "object",
      "description": "Represents a single transaction in the wallet ledger.",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["topup", "call_payment", "payout"] },
        "amount": { "type": "number" },
        "currency": { "type": "string", "default": "COIN" },
        "balanceAfter": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["posted", "pending", "failed"] },
        "callId": { "type": "string" },
        "kind": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "required": ["uid", "type", "amount", "status"]
    },
    "Call": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Call",
      "type": "object",
      "description": "Represents a call between two users.",
      "properties": {
        "id": { "type": "string" },
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "callerName": { "type": "string" },
        "status": { "type": "string", "enum": ["ringing", "accepted", "ended", "declined", "missed", "expired"] },
        "roomUrl": { "type": "string" },
        "roomName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdAtTs": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "acceptedAtTs": { "type": "object" },
        "endedAtTs": { "type": "object" },
        "offerId": { "type": "string" },
        "billedMinutes": { "type": "number" },
        "billedCoins": { "type": "number" },
        "endReason": { "type": "string" },
        "pricingSnapshot": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "ratePerMinute": { "type": "number" },
            "currency": { "type": "string", "default": "COIN" }
          }
        }
      },
      "required": ["callerId", "receiverId", "status", "roomName", "roomUrl"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profile information."
        }
      },
      {
        "path": "/calls/{callId}",
        "definition": {
          "entityName": "Call",
          "schema": { "$ref": "#/backend/entities/Call" },
          "description": "Stores information about calls between users."
        }
      },
      {
        "path": "/walletLedger/{entryId}",
        "definition": {
          "entityName": "WalletLedgerEntry",
          "schema": { "$ref": "#/backend/entities/WalletLedgerEntry" },
          "description": "Stores transaction history."
        }
      }
    ]
  }
}
