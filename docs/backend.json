
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the ConnectU application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "balance": { "type": "number", "default": 0 },
        "held": { "type": "number", "default": 0, "description": "Reserved coins for pending requests" },
        "currency": { "type": "string", "default": "COIN" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "balanceUpdatedAt": { "type": "string", "format": "date-time" },
        "availability": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["online", "offline"] },
            "until": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["id", "email", "name", "createdAt", "balance"]
    },
    "CommunicationRequest": {
      "title": "CommunicationRequest",
      "type": "object",
      "description": "Represents a communication request (Video, Q&A, File or Product Purchase).",
      "properties": {
        "id": { "type": "string" },
        "initiatorId": { "type": "string" },
        "authorId": { "type": "string" },
        "payerId": { "type": "string" },
        "payeeId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "text", "file", "product"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "answered", "completed", "declined", "expired", "ringing"] },
        "offerId": { "type": "string" },
        "productId": { "type": "string" },
        "pricingSnapshot": { "type": "object" },
        "reservedCoins": { "type": "number" },
        "holdId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "answeredAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "lastMessagePreview": { "type": "string" }
      }
    },
    "CommunicationOffer": {
      "title": "CommunicationOffer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "file", "text"] },
        "schedulingType": { "type": "string", "enum": ["instant", "scheduled"], "default": "instant" },
        "scheduledStart": { "type": "string", "format": "date-time" },
        "scheduledEnd": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "pricing": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "inactive", "booked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Digital Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "deliveryText": { "type": "string" },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "A single message in a communication thread.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "kind": { "type": "string", "enum": ["question", "answer", "file", "system"] },
        "text": { "type": "string" },
        "fileMeta": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "channel": { "type": "string", "enum": ["system", "user"] },
        "kind": { "type": "string" },
        "requestId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readAt": { "type": "string", "format": "date-time", "nullable": true }
      }
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "A blog post or update published by a user.",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "viewCount": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorId", "title", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "description": "A comment on a post.",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "text", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "type": "object",
      "description": "Represents a user's bookmark/favorite item.",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "targetId": { "type": "string" },
        "type": { "type": "string", "enum": ["user", "post", "product"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "targetId", "type", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "type": "object",
      "description": "Represents a user's like on a post or product.",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "targetId": { "type": "string" },
        "type": { "type": "string", "enum": ["post", "product"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "targetId", "type", "createdAt"]
    },
    "CallTranslation": {
      "title": "CallTranslation",
      "type": "object",
      "properties": {
        "callId": { "type": "string" },
        "enabled": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["captions_only", "voice_translation"] },
        "status": { "type": "string", "enum": ["idle", "starting", "active", "error", "ended"] },
        "provider": { "type": "string", "default": "azure_speech" },
        "botStatus": { "type": "string", "enum": ["not_joined", "joining", "joined", "processing", "failed", "left"] },
        "participants": { "type": "object" },
        "lastError": { "type": "object" },
        "startedAt": { "type": "string", "format": "date-time" },
        "activatedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "TranslationSegment": {
      "title": "TranslationSegment",
      "type": "object",
      "properties": {
        "speakerUid": { "type": "string" },
        "speakerRole": { "type": "string", "enum": ["caller", "callee"] },
        "sourceLocale": { "type": "string" },
        "targetLocale": { "type": "string" },
        "originalText": { "type": "string" },
        "translatedText": { "type": "string" },
        "isFinal": { "type": "boolean" },
        "sequence": { "type": "number" },
        "status": { "type": "string", "enum": ["partial", "final", "error"] },
        "latencyMs": { "type": "number" },
        "emittedAt": { "type": "string", "format": "date-time" },
        "finalizedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/communicationRequests/{requestId}",
        "definition": { "entityName": "CommunicationRequest", "schema": { "$ref": "#/backend/entities/CommunicationRequest" } }
      },
      {
        "path": "/communicationOffers/{offerId}",
        "definition": { "entityName": "CommunicationOffer", "schema": { "$ref": "#/backend/entities/CommunicationOffer" } }
      },
      {
        "path": "/products/{productId}",
        "definition": { "entityName": "Product", "schema": { "$ref": "#/backend/entities/Product" } }
      },
      {
        "path": "/communicationRequests/{requestId}/messages/{messageId}",
        "definition": { "entityName": "Message", "schema": { "$ref": "#/backend/entities/Message" } }
      },
      {
        "path": "/notifications/{notificationId}",
        "definition": { "entityName": "Notification", "schema": { "$ref": "#/backend/entities/Notification" } }
      },
      {
        "path": "/posts/{postId}",
        "definition": { "entityName": "Post", "schema": { "$ref": "#/backend/entities/Post" } }
      },
      {
        "path": "/posts/{postId}/comments/{commentId}",
        "definition": { "entityName": "Comment", "schema": { "$ref": "#/backend/entities/Comment" } }
      },
      {
        "path": "/favorites/{favoriteId}",
        "definition": { "entityName": "Favorite", "schema": { "$ref": "#/backend/entities/Favorite" } }
      },
      {
        "path": "/likes/{likeId}",
        "definition": { "entityName": "Like", "schema": { "$ref": "#/backend/entities/Like" } }
      },
      {
        "path": "/callTranslations/{callId}",
        "definition": { "entityName": "CallTranslation", "schema": { "$ref": "#/backend/entities/CallTranslation" } }
      },
      {
        "path": "/callTranslations/{callId}/segments/{segmentId}",
        "definition": { "entityName": "TranslationSegment", "schema": { "$ref": "#/backend/entities/TranslationSegment" } }
      }
    ]
  }
}
