
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the ConnectU application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity, matching the Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "User's full name."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "bio": {
          "type": "string",
          "description": "User's biography or short description."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was last updated.",
          "format": "date-time"
        },
        "availability": {
          "type": "object",
          "description": "User's real-time availability status for instant calls.",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "online",
                "offline"
              ]
            },
            "until": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "createdAt"
      ]
    },
    "Call": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Call",
      "type": "object",
      "description": "Represents a call between two users.",
      "properties": {
        "callerId": {
          "type": "string",
          "description": "The UID of the user who initiated the call."
        },
        "callerName": {
          "type": "string",
          "description": "The display name of the user who initiated the call."
        },
        "receiverId": {
          "type": "string",
          "description": "The UID of the user who is being called."
        },
        "status": {
          "type": "string",
          "enum": ["ringing", "accepted", "ended", "declined", "missed", "expired"]
        },
        "roomUrl": {
          "type": "string",
          "description": "URL for the video/audio call room."
        },
        "roomName": {
          "type": "string",
          "description": "Name of the video/audio call room."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "acceptedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp indicating when the ringing call expires and should be considered missed."
        },
        "callerActingAs": {
            "type": "string",
            "enum": ["client", "pro"]
        },
        "receiverActingAs": {
            "type": "string",
            "enum": ["client", "pro"]
        }
      },
      "required": ["callerId", "receiverId", "status", "createdAt", "updatedAt", "roomName", "roomUrl"]
    },
    "CommunicationOffer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CommunicationOffer",
      "type": "object",
      "description": "A proposal for communication services offered by a user.",
      "properties": {
        "ownerId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "file", "text"] },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "pricing": {
          "type": "object",
          "properties": {
            "ratePerMinute": { "type": "number" },
            "ratePerFile": { "type": "number" },
            "ratePerQuestion": { "type": "number" },
            "currency": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "type", "pricing", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profile information.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/calls/{callId}",
        "definition": {
          "entityName": "Call",
          "schema": {
            "$ref": "#/backend/entities/Call"
          },
          "description": "Stores information about calls between users.",
          "params": [
            {
              "name": "callId",
              "description": "The unique identifier for the call."
            }
          ]
        }
      },
      {
        "path": "/communicationOffers/{offerId}",
        "definition": {
          "entityName": "CommunicationOffer",
          "schema": {
            "$ref": "#/backend/entities/CommunicationOffer"
          },
          "description": "Stores communication service proposals.",
          "params": [
            {
              "name": "offerId",
              "description": "The unique identifier for the offer."
            }
          ]
        }
      }
    ]
  }
}
