
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the ConnectU application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "balance": { "type": "number", "default": 0 },
        "currency": { "type": "string", "default": "COIN" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "balanceUpdatedAt": { "type": "string", "format": "date-time" },
        "availability": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["online", "offline"] },
            "until": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["id", "email", "name", "createdAt", "balance"]
    },
    "CommunicationRequest": {
      "title": "CommunicationRequest",
      "type": "object",
      "description": "Represents a non-video communication request (Q&A or File).",
      "properties": {
        "id": { "type": "string" },
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "file"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "declined", "expired"] },
        "offerId": { "type": "string" },
        "pricingSnapshot": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "A single message in a communication thread.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "fileUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WalletLedgerEntry": {
      "title": "WalletLedgerEntry",
      "type": "object",
      "description": "Represents a single transaction in the wallet ledger.",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["topup", "call_payment", "payout"] },
        "amount": { "type": "number" },
        "currency": { "type": "string", "default": "COIN" },
        "balanceAfter": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["posted", "pending", "failed"] },
        "callId": { "type": "string" },
        "kind": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/communicationRequests/{requestId}",
        "definition": { "entityName": "CommunicationRequest", "schema": { "$ref": "#/backend/entities/CommunicationRequest" } }
      },
      {
        "path": "/communicationRequests/{requestId}/messages/{messageId}",
        "definition": { "entityName": "Message", "schema": { "$ref": "#/backend/entities/Message" } }
      },
      {
        "path": "/walletLedger/{entryId}",
        "definition": { "entityName": "WalletLedgerEntry", "schema": { "$ref": "#/backend/entities/WalletLedgerEntry" } }
      }
    ]
  }
}
