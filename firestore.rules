
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isUpdatingProfile() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['name', 'bio', 'avatarUrl', 'updatedAt']);
    }

    function isUpdatingAvailability() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['availability']);
    }

    function isCallParticipant() {
      return isSignedIn()
        && (resource.data.callerId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
    }

    // ---------- Users ----------
    match /users/{uid} {
      allow read: if true;
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) && (isUpdatingProfile() || isUpdatingAvailability());
      allow delete: if false;
    }

    // ---------- Wallet Ledger ----------
    match /walletLedger/{entryId} {
      allow read: if isSignedIn() && isOwner(resource.data.uid);
      allow write: if false;
    }

    // ---------- Calls (1:1 video) ----------
    match /calls/{callId} {
      allow read: if isCallParticipant();
      allow create, update, delete: if false;
    }

    // ---------- Communication Offers ----------
    match /communicationOffers/{offerId} {
      // Explicitly allow both single document read (get) and collection query (list)
      allow read: if true;
      
      // Ownership rules for mutations
      allow create: if isSignedIn() && isSelf(request.resource.data.ownerId);
      allow update, delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // ---------- Default: deny all other access ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
