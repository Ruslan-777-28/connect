rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------- Users ----------
    match /users/{uid} {
      // Будь-який авторизований користувач може бачити профілі інших
      allow get, list: if isSignedIn();
      
      // Створювати та редагувати профіль може тільки сам користувач
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // ---------- Wallet Ledger ----------
    match /walletLedger/{txId} {
      // Користувач бачить тільки свою історію транзакцій. 
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      // Записи в реєстр робить тільки сервер (Cloud Functions)
      allow create, update, delete: if false;
    }

    // ---------- Communication Offers ----------
    match /communicationOffers/{offerId} {
      // ✅ Усі авторизовані користувачі можуть переглядати пропозиції (get та list)
      allow get, list: if isSignedIn();
      
      // ✅ Створювати пропозицію може тільки власник
      allow create: if isSignedIn() 
        && request.resource.data.ownerId == request.auth.uid;
      
      // ✅ Редагувати або видаляти пропозицію може тільки її автор
      allow update, delete: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid;
    }

    // ---------- Calls (1:1 video) ----------
    match /calls/{callId} {
      function isCallParticipant() {
        return isSignedIn() && (
          resource.data.callerId == request.auth.uid || 
          resource.data.receiverId == request.auth.uid
        );
      }
      
      // Тільки учасники дзвінка можуть його бачити
      allow read: if isCallParticipant();
      
      // Стан дзвінків змінюється тільки через серверні функції
      allow create, update, delete: if false;
    }
    
    // ---------- Daily Rooms Mapping ----------
    match /dailyRooms/{roomName} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---------- Default: deny all other access ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
