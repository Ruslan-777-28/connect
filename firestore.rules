rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isCallParticipant() {
      return isSignedIn()
        && (resource.data.callerUid == request.auth.uid
            || resource.data.receiverUid == request.auth.uid);
    }

    // ---------- Default: deny all access ----------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------- Users ----------
    // Allow signed in users to read profiles.
    // Allow users to create and update their own profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid);
      allow delete: if false; // Disallow client-side deletion for safety
    }

    // ---------- Calls (1:1 video) ----------
    // Allow only call participants to read the call document.
    // All writes are handled by Cloud Functions.
    match /calls/{callId} {
      allow read: if isCallParticipant();
      allow create, update, delete: if false;
    }
  }
}
