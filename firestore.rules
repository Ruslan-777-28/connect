
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------- Users ----------
    match /users/{uid} {
      allow get, list: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // ---------- Products ----------
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // ---------- Notifications ----------
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Wallet Ledger ----------
    match /walletLedger/{txId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Wallet Holds ----------
    match /walletHolds/{holdId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ---------- Communication Offers ----------
    match /communicationOffers/{offerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ---------- Communication Requests & Messages ----------
    match /communicationRequests/{requestId} {
      function isParticipant() {
        return isSignedIn() && (
          resource.data.initiatorId == request.auth.uid || 
          resource.data.authorId == request.auth.uid
        );
      }
      
      allow read: if isParticipant();
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/communicationRequests/$(requestId)).data.initiatorId == request.auth.uid || 
          get(/databases/$(database)/documents/communicationRequests/$(requestId)).data.authorId == request.auth.uid
        );
        allow create, update, delete: if false;
      }
    }

    // ---------- Posts ----------
    match /posts/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      }
    }

    // ---------- Favorites ----------
    match /favorites/{favoriteId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ---------- Likes ----------
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ---------- Calls & Translations ----------
    match /calls/{callId} {
      function isCallParticipant() {
        return isSignedIn() && (
          resource.data.callerId == request.auth.uid || 
          resource.data.receiverId == request.auth.uid
        );
      }
      allow read: if isCallParticipant();
      allow create, update, delete: if false;
    }

    match /callTranslations/{callId} {
      function isTranslationParticipant() {
        return isSignedIn() && (
          request.auth.uid in resource.data.participants
        );
      }
      allow read: if isTranslationParticipant();
      allow write: if false; // Only written by Translator Bot Service

      match /segments/{segmentId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/callTranslations/$(callId)).data.participants[request.auth.uid] != null
        );
        allow write: if false; // Only written by Translator Bot Service
      }
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
