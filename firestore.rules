rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isUpdatingProfile() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['name', 'bio', 'avatarUrl', 'updatedAt']);
    }

    function isUpdatingAvailability() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['availability']);
    }

    function isCallParticipant() {
      return isSignedIn()
        && (resource.data.callerId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
    }

    // ---------- Default: deny all access ----------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------- Users ----------
    // Allow signed in users to read profiles.
    // Allow users to create their own profile.
    // Allow users to update specific fields of their own profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) && (isUpdatingProfile() || isUpdatingAvailability());
      allow delete: if false; // Disallow client-side deletion for safety
    }

    // ---------- Calls (1:1 video) ----------
    // Allow only call participants to read the call document.
    // All writes are handled by Cloud Functions.
    match /calls/{callId} {
      allow read: if isCallParticipant();
      allow create, update, delete: if false;
    }
  }
}
