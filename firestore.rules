rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isCallParticipant() {
      return isSignedIn()
        && (resource.data.callerUid == request.auth.uid
            || resource.data.receiverUid == request.auth.uid);
    }

    // ---------- Default: deny ----------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------- Users ----------
    // Мінімально: юзер може читати (авториз.), змінювати тільки свій профіль
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // ---------- Calls (1:1 video) ----------
    // ВАЖЛИВО: створення/оновлення робиться Cloud Functions, клієнт тільки читає
    match /calls/{callId} {
      // учасники можуть читати (слухати статус)
      allow read: if isCallParticipant();

      // ніхто з клієнта не створює/не змінює/не видаляє
      allow create, update, delete: if false;
    }
  }
}
