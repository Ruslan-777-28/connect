rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Rules for user avatars
    match /avatars/{userId} {
      // Anyone can read avatars to display them in user profiles and lists.
      allow read;
      // Only the authenticated user can upload or update their own avatar.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
